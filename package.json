{
  "name": "bolt-expo-starter",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 expo start",
    "dev:web": "cross-env EXPO_NO_TELEMETRY=1 expo start --web",
    "build:web": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && expo export --platform web && node scripts/copy-public-assets.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "check:assets": "node scripts/check-public-assets.mjs",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@lucide/lab": "^0.1.2",
    "@react-navigation/bottom-tabs": "^7.2.0",
    "@react-navigation/native": "^7.0.14",
    "expo": "^54.0.10",
    "expo-blur": "~15.0.7",
    "expo-constants": "~18.0.9",
    "expo-font": "~14.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-router": "~6.0.8",
    "expo-splash-screen": "~31.0.10",
    "expo-status-bar": "~3.0.8",
    "html2canvas": "^1.4.1",
    "lucide-react": "^1.14.0",
    "lucide-react-native": "^0.544.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~19.1.10",
    "cross-env": "^10.1.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~10.0.0",
    "sharp": "^0.35.3",
    "typescript": "~5.9.2"
  }
}
